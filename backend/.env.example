# LLM API Configuration
# 使用阿里云 DashScope（通义千问）API
# 获取 API Key: https://help.aliyun.com/zh/model-studio/developer-reference/get-api-key
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo
LLM_EMBEDDING_MODEL=text-embedding-v3

# 如果使用 OpenAI API，修改以下配置：
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_EMBEDDING_MODEL=text-embedding-ada-002

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
RRF_K=60

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
